# ══════════════════════════════════════════════════════
#  Chatcat Pro — Dashboard Environment Variables
#  Copy to .env for local dev, or set in Vercel for production.
# ══════════════════════════════════════════════════════

# Production (Vercel): set to your real API domain
VITE_API_BASE=https://api.chatcat.pro

# Local development: comment the above and uncomment below.
# The vite dev server will proxy /api → localhost:3000 automatically.
# VITE_API_BASE=http://localhost:3000
