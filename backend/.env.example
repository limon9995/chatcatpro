# ══════════════════════════════════════════════════════
#  Chatcat Pro — Backend Environment Variables
#  Copy to .env and fill in real values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://chatcat:StrongPassHere@localhost:5432/chatcatpro"

# ── Auth ──────────────────────────────────────────────
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=ChangeThisPassword123!
AUTH_ADMIN_EMAIL=admin@chatcat.pro

# ── Encryption ────────────────────────────────────────
# Used for AES-256 encryption of stored Facebook tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be 32+ characters. Keep this secret — losing it breaks all stored tokens.
FB_TOKEN_ENCRYPTION_KEY=replace-with-64-char-hex-string-generated-by-crypto

# ── Facebook Webhook ──────────────────────────────────
# Found in Meta Developer Console → Your App → Settings → Basic → App Secret
FB_WEBHOOK_SECRET=your_facebook_app_secret_here

# ── Facebook OAuth (for "Connect Page" flow) ──────────
FB_OAUTH_STATE_SECRET=replace-with-random-secret-for-oauth-state-signing
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_REDIRECT_URI=https://api.chatcat.pro/facebook/callback

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty to allow ALL origins (not recommended for production).
CORS_ORIGINS=https://chatcat.pro,https://www.chatcat.pro

# ── Public URLs ───────────────────────────────────────
LANDING_PAGE_URL=https://chatcat.pro
STORAGE_PUBLIC_URL=https://api.chatcat.pro/storage

# ── Gmail OTP (for email verification / password reset) ──
GMAIL_USER=otp@chatcat.pro
GMAIL_APP_PASSWORD=your_gmail_app_password_here
