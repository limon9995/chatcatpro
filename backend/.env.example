NODE_ENV=development
PORT=3000

# Required core settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/df_bot
FB_TOKEN_ENCRYPTION_KEY=replace-with-a-random-32-char-secret
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change-me-please

# Web + storage URLs
LANDING_PAGE_URL=http://localhost:3000
STORAGE_PUBLIC_URL=http://localhost:3000/storage
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Facebook / Meta
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=http://localhost:3000/facebook/callback
FB_OAUTH_STATE_SECRET=replace-with-another-random-secret
FB_WEBHOOK_SECRET=
DEFAULT_VERIFY_TOKEN=local-dev-token

# Optional OpenAI providers
# Keep this file local only: copy to backend/.env and paste your new key there.
OPENAI_API_KEY=
FALLBACK_AI_PROVIDER=mock
FALLBACK_AI_MODEL=gpt-4o
VISION_PROVIDER=mock
VISION_MODEL=gpt-4o

# Queue
REDIS_URL=redis://127.0.0.1:6379
